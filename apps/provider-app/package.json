{
  "name": "provider-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "pwa:build": "expo export --platform web && node scripts/pwa-inject.mjs",
    "pwa:deploy": "firebase deploy --only hosting:provider-pwa",
    "pwa:preview": "firebase hosting:channel:deploy preview --only hosting:provider-pwa",
    "cf:build": "expo export --platform web",
    "cf:deploy": "expo export --platform web && npx wrangler pages deploy dist --project-name skids-provider"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-navigation/bottom-tabs": "^7.3.0",
    "@react-navigation/native": "^7.1.0",
    "@react-navigation/native-stack": "^7.3.0",
    "@skids/firebase": "*",
    "@skids/ui": "*",
    "@skids/ai-scribe-local": "*",
    "expo": "~54.0.33",
    "expo-av": "~15.1.3",
    "expo-build-properties": "^55.0.9",
    "expo-status-bar": "~3.0.9",
    "firebase": "^11.6.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.21.0",
    "react-native-webrtc": "^124.0.7",
    "react-native-worklets": "^0.7.4"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
